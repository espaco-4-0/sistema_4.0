#adicione aqui o database url do seu banco de dados local
#rode o npx prisma seed caso tenha duvida entre la no prisma aqui ou na propia documentacao dele mesmo

DATABASE_URL=

# Redis local (docker-compose)
REDIS_URL=redis://

# Redis via REST (necessario para rate limit no proxy/middleware em Edge)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limit do proxy
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
