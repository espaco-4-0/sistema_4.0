enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String?
  capacity    Int?
  durationMin Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Lesson        Lesson[]
  VisitLocation VisitLocation[]
}

model Course {
  id           String   @id @default(cuid())
  title        String
  description  String?
  workload     Int? // em horas
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  professor   User   @relation(fields: [professorId], references: [id])
  professorId String

  Lesson        Lesson[]
  Enrollment    Enrollment[]

  @@index([professorId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String?
  startDate   DateTime
  durationMin Int // duração em minutos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id])
  courseId String

  professor   User   @relation("ProfessorAulas", fields: [professorId], references: [id])
  professorId String

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String? // opcional: pode ser definido depois

  LessonMonitor LessonMonitor[]
  Presence      Presence[]

  @@index([courseId])
  @@index([professorId])
}

model LessonMonitor {
  id        String @id @default(cuid())
  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  monitor   User   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  monitorId String

  assignedAt DateTime @default(now())

  @@unique([lessonId, monitorId])
  @@index([monitorId])
}

model Enrollment {
  id         String           @id @default(cuid())
  status     EnrollmentStatus @default(PENDING)
  chosenDate DateTime? // data/hora preferida pelo visitante
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  Presence Presence[]

  @@unique([userId, courseId])
  @@index([courseId])
}

model Presence {
  id          String    @id @default(cuid())
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String

  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])
  enrollmentId String?

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([enrollmentId])
}
