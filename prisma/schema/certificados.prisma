model Certificate {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  cargaHoraria Int?
  arquivoUrl  String
  curso       String?
  turmaId     String?
  validadeAte DateTime?
  status      String   @default("ATIVO")
  emitidoPor  String
  createdAt   DateTime @default(now())

  emissor     User     @relation("ProfessorCertificados", fields: [emitidoPor], references: [id])
  inscricoes  CertificateSubscription[]
  emissoes    CertificateEmission[]
}

model CertificateSubscription {
  id            String   @id @default(uuid())
  certificateId String
  alunoId       String
  createdAt     DateTime @default(now())

  certificate   Certificate @relation(fields: [certificateId], references: [id])
  aluno         User        @relation(fields: [alunoId], references: [id])

  @@unique([certificateId, alunoId])
}

model CertificateEmission {
  id             String   @id @default(uuid())
  certificateId  String
  alunoId        String
  arquivoUrl     String
  emitidoEm      DateTime @default(now())
  emitidoPor     String
  ultimoDownload DateTime?
  totalDownloads Int      @default(0)

  certificate    Certificate @relation(fields: [certificateId], references: [id])
  aluno          User        @relation(fields: [alunoId], references: [id])

  @@unique([certificateId, alunoId])
}
