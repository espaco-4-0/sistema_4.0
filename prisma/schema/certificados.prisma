model CertificateTemplate {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String
  workload    Int?
  layout      Json
  fileUrl     String?
  course      String?
  classId     String?
  validUntil  DateTime?
  status      String   @default("ACTIVE")
  emittedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  emittedByUser User                    @relation("ProfessorCertificados", fields: [emittedBy], references: [id])
  inscricoes    CertificateSubscription[]
  emissoes      CertificateEmission[]
}

model CertificateSubscription {
  id         String   @id @default(uuid())
  templateId String
  alunoId    String
  createdAt  DateTime @default(now())

  certificate CertificateTemplate @relation(fields: [templateId], references: [id])
  aluno       User                @relation(fields: [alunoId], references: [id])

  @@unique([templateId, alunoId])
}

model CertificateEmission {
  id               String    @id @default(uuid())
  templateId       String
  alunoId          String
  fileUrl          String
  emittedAt        DateTime  @default(now())
  emittedBy        String
  validUntil       DateTime?
  lastDownloadedAt DateTime?
  totalDownloads   Int       @default(0)
  course           String

  certificate CertificateTemplate @relation(fields: [templateId], references: [id])
  aluno       User                @relation(fields: [alunoId], references: [id])

  @@unique([templateId, alunoId])
}
