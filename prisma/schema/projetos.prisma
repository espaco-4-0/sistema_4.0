enum ProjectType {
  EXTENSION
  RESEARCH
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        ProjectType
  status      ProjectStatus @default(IN_PROGRESS)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  leader   User   @relation("LiderProjeto", fields: [leaderId], references: [id])
  leaderId String

  ProjectMember ProjectMember[]
  ProjectPhoto  ProjectPhoto[]
  ProjectReport ProjectReport[]
  InventoryItem InventoryItem[]

  @@index([leaderId])
}

model ProjectMember {
  id       String   @id @default(cuid())
  role     String? // ex: "pesquisador", "bolsista"
  joinedAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
}

model ProjectReport {
  id          String    @id @default(cuid())
  title       String
  content     String
  fileUrl     String? // PDF ou outro anexo
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
}
