enum UserRole {
    ADMIN // Administrador – acesso total ao sistema
    PROFESSOR // Define cursos, aulas, horários e locais
    MONITOR // Acompanha aulas; nível abaixo do professor
    PESQUISADOR // Semelhante ao monitor; foco em pesquisa
    VISITANTE // Escolhe curso/data/hora e confirma presença
}

enum Race {
    BRANCA
    PRETA
    PARDA
    AMARELA
    INDIGENA
    NÃO_INFORMADA
}

enum Education {
    FUNDAMENTAL_INCOMPLETO
    FUNDAMENTAL_COMPLETO
    MEDIO_CURSANDO
    MEDIO_COMPLETO
    SUPERIOR_CURSANDO
    SUPERIOR_COMPLETO
}

enum IfalAfiliation {
    ALUNO
    EX_ALUNO
    NÃO_ALUNO
}

model User {
    id                  String         @id @default(cuid())
    nomeCompleto        String
    email               String         @unique
    senha               String
    dataNascimento      DateTime
    telefone            String
    raca                Race
    educacao            Education
    ifalAfiliacao       IfalAfiliation
    deficiencia         String?
    necessidadeEspecial String?
    role                UserRole       @default(VISITANTE)
    avatarUrl           String?
    ativo               Boolean        @default(true)
    createdAt           DateTime       @default(now())
    updatedAt           DateTime       @updatedAt

    // Relações – Professor
    cursosMinistrados Curso[] @relation("ProfessorCursos")
    aulasMinistradas  Aula[]  @relation("ProfessorAulas")

    // Relações – Monitor / Pesquisador
    monitoramentos AulaMonitor[]

    // Relações – Visitante
    inscricoes Inscricao[]
    presencas  Presenca[]

    // Inventário
    itensInventario InventarioItem[]

    // Blog
    posts       Post[]
    comentarios Comentario[]
    curtidas    Curtida[]

    // Projetos
    projetosLiderados Projeto[]       @relation("LiderProjeto")
    projetosMembro    ProjetoMembro[]

    // Gamificação
    gamificacao Gamificacao?
    userBadges  UserBadge[]

    // Certificados
    certificados Certificado[]
}
