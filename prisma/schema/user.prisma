enum UserRole {
  ADMIN // Administrador – acesso total ao sistema
  PROFESSOR // Define cursos, aulas, horários e locais
  MONITOR // Acompanha aulas; nível abaixo do professor
  RESEARCHER // Semelhante ao monitor; foco em pesquisa
  VISITOR // Escolhe curso/data/hora e confirma presença
}

enum Race {
  WHITE
  BLACK
  BROWN
  YELLOW
  INDIGENOUS
  NOT_DECLARED
}

enum Education {
  PRIMARY_INCOMPLETE
  PRIMARY_COMPLETE
  HIGH_SCHOOL_IN_PROGRESS
  HIGH_SCHOOL_COMPLETE
  HIGHER_EDUCATION_IN_PROGRESS
  HIGHER_EDUCATION_COMPLETE
}

enum IfalAffiliation {
  STUDENT
  ALUMNI
  NOT_STUDENT
  STAFF
}

model User {
  id                  String          @id @default(cuid())
  fullName            String
  email               String          @unique
  password            String
  birthDate           DateTime        @db.Date
  phone               String
  race                Race
  education           Education
  ifalAffiliation     IfalAffiliation
  disability          String?
  specialNeed         String?
  role                UserRole        @default(VISITOR)
  avatarUrl           String?
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  resetToken          String?
  resetTokenExpiresAt DateTime?

  // Relações – Professor
  Course              Course[]
  Lesson              Lesson[]        @relation("ProfessorAulas")

  // Relações – Monitor / Pesquisador
  LessonMonitor       LessonMonitor[]

  // Relações – Visitante
  Enrollment          Enrollment[]
  Presence            Presence[]

  // Inventário
  resources       	  Resource[]

  // Blog
  Post                Post[]
  Comment             Comment[]
  Like                Like[]

  // Projetos
  Project             Project[]       @relation("LiderProjeto")
  ProjectMember       ProjectMember[]

  // Gamificação
  Gamification        Gamification?
  userBadges          UserBadge[]

  // Certificados
  CertificateTemplate   CertificateTemplate[]   @relation("ProfessorCertificados")
  certificadosInscritos CertificateSubscription[]
  certificadosEmissoes  CertificateEmission[]
}
