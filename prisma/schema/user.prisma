enum UserRole {
  ADMIN // Administrador – acesso total ao sistema
  TEACHER // Define cursos, aulas, horários e locais
  MONITOR // Acompanha aulas; nível abaixo do professor
  RESEARCHER // Semelhante ao monitor; foco em pesquisa
  VISITOR // Escolhe curso/data/hora e confirma presença
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  nome      String
  senha     String
  role      UserRole @default(VISITOR)
  avatarUrl String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações – Professor
  cursosMinistrados Curso[] @relation("ProfessorCursos")
  aulasMinistradas  Aula[]  @relation("ProfessorAulas")

  // Relações – Monitor / Pesquisador
  monitoramentos AulaMonitor[]

  // Relações – Visitante
  inscricoes Inscricao[]
  presencas  Presenca[]

  // Inventário
  itensInventario InventarioItem[]

  // Blog
  posts       Post[]
  comentarios Comentario[]
  curtidas    Curtida[]

  // Projetos
  projetosLiderados Projeto[]       @relation("LiderProjeto")
  projetosMembro    ProjetoMembro[]

  // Gamificação
  gamificacao Gamificacao?
  userBadges  UserBadge[]

  // Certificados
  certificados Certificado[]
}
